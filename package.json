{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/mp3/(.*)",
      "dest": "/mp3/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}